rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──
    // Anyone signed in can read any user profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId;   // users can only edit their own profile
    }

    // ── Lessons (public, admin-managed) ──
    // everyone can read published lessons; only admins can write
    match /lessons/{lessonId} {
      allow read: if true;
      allow list: if true;
      allow create, update, delete: if request.auth != null
                                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // Sub-collections: sections & exercises
      match /sections/{sectionId} {
        allow read, list: if true;
        allow create, update, delete: if request.auth != null
                                      && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }
      match /exercises/{exerciseId} {
        allow read, list: if true;
        allow create, update, delete: if request.auth != null
                                      && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }
    }

    // ── Progress / Learning Tracking ──
    //
    // Top-level progress/{uid} doc — no leaf data, only a path anchor.
    // Authenticated users can read their own; everyone can list the anchor.
    match /progress/{userId} {
      allow read, list: if request.auth != null
                        && request.auth.uid == userId;
      allow create, update, delete: if request.auth != null
                                    && request.auth.uid == userId;

      // ┌─────────────────────────────────────────────────────────────────┐
      // │  lessons/{lessonId}  ← individual per-lesson progress document   │
      // │  ID  ==  lessonId  (e.g. "lesson-1", "lesson-2", …)             │
      // └─────────────────────────────────────────────────────────────────┘
      // Only the owner (uid == {userId}) may read / write / delete
      match /lessons/{lessonId} {
        allow create: if request.auth != null
                      && request.auth.uid == userId;

        allow read:   if request.auth != null
                      && request.auth.uid == userId;

        allow update: if request.auth != null
                      && request.auth.uid == userId
                      && // Prevent changing userId field (ownership guard)
                         (request.resource.data.userId == null
                          || request.resource.data.userId == userId);

        allow delete: if request.auth != null
                      && request.auth.uid == userId;

        // Extra guard: deny deep traversal past the lesson doc
        // (no further sub-collections are defined here)
      }
    }

    // ── Fallback: deny everything not explicitly allowed above ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
